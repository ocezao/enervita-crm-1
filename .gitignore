```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Environment variables
.env
.env.local
.env.*

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.coverage
coverage/
htmlcov/
.mypy_cache/
.pytest_cache/
.tox/

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak

# Compressed files
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z
```