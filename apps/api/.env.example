# Local PostgreSQL connection used by database scripts.
DATABASE_URL=postgres://enervita:enervita@localhost:5432/enervita_crm

# Database Pool Configuration (optimized defaults in code)
# These values are configured in src/db/pool.ts but can be overridden via env if needed
# DB_POOL_MAX=20              # Maximum connections in pool
# DB_POOL_MIN=4               # Minimum idle connections to maintain
# DB_POOL_IDLE_TIMEOUT=30000  # Max idle time before connection is removed (ms)
# DB_POOL_CONNECTION_TIMEOUT=5000  # Max wait time for available connection (ms)

# Initial local admin seed. Use non-production test credentials only.
ADMIN_EMAIL=
ADMIN_NAME=
ADMIN_INITIAL_PASSWORD=
